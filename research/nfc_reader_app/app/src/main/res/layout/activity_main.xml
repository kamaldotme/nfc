<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Full-screen animated bubble canvas -->
    <com.nfcresearch.reader.BubbleView
        android:id="@+id/bubbleView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top bar overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="36dp"
        android:paddingBottom="12dp"
        android:background="#66000000">

        <TextView
            android:layout_width="0dp"
            android:id="@+id/tvTitle"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="GEOMETRY SAVER"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCORE"
                android:textColor="#aaaaaa"
                android:textSize="10sp"
                android:letterSpacing="0.15"/>

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#58a6ff"
                android:textSize="28sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Center tap ring -->
    <FrameLayout
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="center">

        <!-- outer ring -->
        <View
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:background="@drawable/ring_outer" />

        <!-- inner ring -->
        <View
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_gravity="center"
            android:background="@drawable/ring_inner" />

        <!-- center label -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◈"
                android:textColor="#58a6ff"
                android:textSize="36sp"/>

            <TextView
                android:id="@+id/tvCenterLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="READY"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"/>
        </LinearLayout>
    </FrameLayout>

    <!-- Bottom status — game-style only, no card data -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp"
        android:paddingTop="12dp"
        android:background="#66000000"
        android:gravity="center">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hold card to capture geometry"
            android:textColor="#aaaaaa"
            android:textSize="13sp"
            android:gravity="center"/>

        <!-- level dots -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <View android:id="@+id/dot1"
                android:layout_width="8dp" android:layout_height="8dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/dot_active"/>
            <View android:id="@+id/dot2"
                android:layout_width="8dp" android:layout_height="8dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/dot_inactive"/>
            <View android:id="@+id/dot3"
                android:layout_width="8dp" android:layout_height="8dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/dot_inactive"/>
            <View android:id="@+id/dot4"
                android:layout_width="8dp" android:layout_height="8dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/dot_inactive"/>
            <View android:id="@+id/dot5"
                android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/dot_inactive"/>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
